      "type": "shell",
      "command": "make",
      "args": ["-C", "${workspaceFolder}", "starter-verify"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "catalog: build",
      "type": "shell",
      "command": "make",
      "args": ["-C", "${workspaceFolder}", "catalog"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "catalog: build and verify",
      "type": "shell",
      "command": "make",
      "args": ["-C", "${workspaceFolder}", "catalog-verify"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "validate: package and slides",
      "type": "shell",
      "command": "make",
      "args": ["-C", "${workspaceFolder}", "validate"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "package: install locally",
      "type": "shell",
      "command": "make",
      "args": ["-C", "${workspaceFolder}", "install"],
